{
  "name": "claude-global-config",
  "version": "1.0.0",
  "description": "Configuración global de Claude Code — instalador automático",
  "keywords": ["claude", "claude-code", "anthropic"],
  "homepage": "https://github.com/sanvelasaez/claude-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanvelasaez/claude-config.git"
  },
  "bin": {
    "claude-global-config": "./bin/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "validate": "node scripts/validate-skills.js",
    "check": "node bin/install.js --check",
    "update-skills": "node scripts/update-skills.js",
    "update-skills:check": "node scripts/update-skills.js --check",
    "update-skills:own": "node scripts/update-skills.js --own",
    "update-skills:external": "node scripts/update-skills.js --external",
    "merge-skills": "node scripts/merge-skill-extension.js --all",
    "merge-skill": "node scripts/merge-skill-extension.js"
  }
}
