{
  "_descripcion": "Configuración global de Claude Code. Copiar a ~/.claude/settings.json en cada instalación nueva.",
  "language": "Español",
  "skillListingBudgetFraction": 0.01,
  "model": "haiku",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Write(**/dist/**)",
      "Write(**/build/**)",
      "Write(**/node_modules/**)",
      "Bash(rm -rf *)",
      "Bash(sudo rm *)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "PowerShell(Remove-Item*-Recurse*)",
      "PowerShell(Invoke-Expression *)",
      "PowerShell(iex *)",
      "PowerShell(Format-Volume*)"
    ],
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "PowerShell(Get-ChildItem*)",

      "mcp__centinel__check_ioc",
      "mcp__centinel__scan_package",
      "mcp__centinel__add_ioc",
      "mcp__centinel__ioc_stats",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_stats",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_search",

      "Bash(rtk *)",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(npx *)",
      "Bash(npx skills *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(python3 -c *)",
      "Bash(python *)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(mvn *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(ruby *)",
      "Bash(gem install*)",
      "Bash(bundle *)",
      "Bash(dotnet *)",
      "Bash(dart *)",
      "Bash(flutter *)",
      "Bash(php *)",
      "Bash(composer *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git -C status)",
      "Bash(git -C diff)",
      "Bash(git -C log*)",
      "Bash(gh api *)",
      "Bash(curl -s *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(Select-Object Name)",
      "Bash(Sort-Object Name)",

      "PowerShell(rtk *)",
      "PowerShell(npm *)",
      "PowerShell(node *)",
      "PowerShell(python3 *)",
      "PowerShell(python *)",
      "PowerShell(pip *)",
      "PowerShell(java *)",
      "PowerShell(javac *)",
      "PowerShell(mvn *)",
      "PowerShell(gradle *)",
      "PowerShell(go *)",
      "PowerShell(cargo *)",
      "PowerShell(ruby *)",
      "PowerShell(gem install*)",
      "PowerShell(bundle *)",
      "PowerShell(dotnet *)",
      "PowerShell(dart *)",
      "PowerShell(flutter *)",
      "PowerShell(php *)",
      "PowerShell(composer *)",
      "PowerShell(git status)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",
      "PowerShell(Get-Command *)",

      "WebSearch",
      "Bash(winget *)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:skills.sh)",
      "WebFetch(domain:api.osv.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(claude *)",
      "Skill"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"C:/Users/santi/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ],
    // "PreToolUse": [
    //   {
    //     "matcher": "Bash",
    //     "hooks": [
    //       {
    //         "type": "command",
    //         "command": "rtk hook claude"
    //       }
    //     ]
    //   }
    // ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "mcp__context-mode__ctx_fetch_and_index",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      }
    ],
    "enabledPlugins": {
      "context-mode@context-mode": true,
      "skill-creator@claude-plugins-official": true,
      "claude-md-management@claude-plugins-official": true,
      "security-guidance@claude-plugins-official": true,
      "caveman@caveman": true
    },
    "extraKnownMarketplaces": {
      "claude-plugins-official": {
        "source": {
          "source": "github",
          "repo": "anthropics/claude-plugins-official"
        }
      },
      "context-mode": {
        "source": {
          "source": "github",
          "repo": "mksglu/context-mode"
        }
      },
      "caveman": {
        "source": {
          "source": "github",
          "repo": "JuliusBrussee/caveman"
        }
      }
    }
  }
}