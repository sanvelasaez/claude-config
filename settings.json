{
  "_descripcion": "Configuración global de Claude Code. Copiar a ~/.claude/settings.json en cada instalación nueva.",
  "language": "Español",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Write(**/dist/**)",
      "Write(**/build/**)",
      "Write(**/node_modules/**)",
      "Bash(rm -rf *)",
      "Bash(sudo rm *)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "PowerShell(Remove-Item*-Recurse*)",
      "PowerShell(Invoke-Expression *)",
      "PowerShell(iex *)",
      "PowerShell(Format-Volume*)"
    ],
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(.claude/**)",

      "mcp__centinel__check_ioc",
      "mcp__centinel__scan_package",
      "mcp__centinel__add_ioc",
      "mcp__centinel__ioc_stats",

      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(mvn *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(ruby *)",
      "Bash(gem install*)",
      "Bash(bundle *)",
      "Bash(dotnet *)",
      "Bash(dart *)",
      "Bash(flutter *)",
      "Bash(php *)",
      "Bash(composer *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",

      "PowerShell(npm *)",
      "PowerShell(node *)",
      "PowerShell(python3 *)",
      "PowerShell(python *)",
      "PowerShell(pip *)",
      "PowerShell(java *)",
      "PowerShell(javac *)",
      "PowerShell(mvn *)",
      "PowerShell(gradle *)",
      "PowerShell(go *)",
      "PowerShell(cargo *)",
      "PowerShell(ruby *)",
      "PowerShell(gem install*)",
      "PowerShell(bundle *)",
      "PowerShell(dotnet *)",
      "PowerShell(dart *)",
      "PowerShell(flutter *)",
      "PowerShell(php *)",
      "PowerShell(composer *)",
      "PowerShell(git status)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",

      "WebFetch(https://**)",
      "WebFetch(domain:skills.sh)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/centinel_preflight.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const fs=require('fs'),path=require('path'),os=require('os');const fp=JSON.parse(process.env.CLAUDE_TOOL_INPUT||'{}').file_path||'?';const line='['+new Date().toISOString().slice(0,19).replace('T',' ')+'] WRITE: '+fp;fs.appendFileSync(path.join(os.homedir(),'.claude','audit.log'),line+'\\n')}catch(e){}\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const fs=require('fs'),path=require('path'),os=require('os');const line='['+new Date().toISOString().slice(0,19).replace('T',' ')+'] SESSION START - dir: '+process.cwd();fs.appendFileSync(path.join(os.homedir(),'.claude','sessions.log'),line+'\\n')}catch(e){}\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{const fs=require('fs'),path=require('path'),os=require('os');const line='['+new Date().toISOString().slice(0,19).replace('T',' ')+'] SESSION END';fs.appendFileSync(path.join(os.homedir(),'.claude','sessions.log'),line+'\\n')}catch(e){}\""
          }
        ]
      }
    ]
  }
}
