  "dangerous_command_patterns": {
    "pipe_to_shell": [
      "curl.*\\|.*bash",
      "curl.*\\|.*sh",
      "wget.*\\|.*bash",
      "wget.*\\|.*sh",
      "fetch.*\\|.*bash",
      "python.*<\\(curl",
      "python3.*<\\(curl"
    ],
    "reverse_shells": [
      "bash.*-i.*>&.*/dev/tcp",
      "nc.*-e.*/bin",
      "ncat.*-e.*/bin",
      "python.*socket.*connect",
      "python3.*socket.*connect",
      "perl.*socket.*connect",
      "ruby.*TCPSocket",
      "php.*fsockopen",
      "socat.*exec",
      "mkfifo.*/tmp.*nc"
    ],
    "data_exfiltration": [
      "base64.*\\|.*curl",
