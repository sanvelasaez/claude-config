      "eval.*\\$\\(",
      "exec.*base64",
      "exec.*\\$\\(",
      "__import__.*eval",
      "subprocess.*shell=True.*input"
    ],
    "persistence": [
      "crontab.*-l.*\\|.*crontab",
      "echo.*>>.*crontab",
      "echo.*>>.*\\.bashrc",
      "echo.*>>.*\\.zshrc",
      "echo.*>>.*\\.profile",
      "echo.*>>.*\\.bash_profile",
      "launchctl.*load",
      "systemctl.*enable.*--now",
      "reg.*add.*HKLM.*Run",
      "schtasks.*\\/create"
    ],
    "privilege_escalation": [
      "chmod.*777",
      "chmod.*4755",
      "chown.*root",
      "sudo.*-s",
      "sudo.*su",
      "pkexec"
    ],
    "destructive": [
      "rm -rf /",
      "rm -rf ~",
      "rm -rf \\$HOME",
      "DROP TABLE",
      "DROP DATABASE",
      "DELETE FROM.*WHERE.*1=1",
      "format c:",
      "format.*\\/q",
      "mkfs",
      "dd if=.*of=/dev",
      "shred.*-uz"
    ]
